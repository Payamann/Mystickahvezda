* text=auto

# Source and project metadata should stay LF across platforms.
*.cjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.sql text eol=lf
*.svg text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary assets.
*.avif binary
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.mp3 binary
*.mp4 binary
*.png binary
*.webp binary
*.woff binary
*.woff2 binary
