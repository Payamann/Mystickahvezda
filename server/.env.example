SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
JWT_SECRET=YOUR_JWT_SECRET
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
# Optional overrides. Leave empty for local test keys; live mode uses configured Stripe Price IDs by default.
STRIPE_PERSONAL_MAP_PRICE_ID=
STRIPE_ANNUAL_HOROSCOPE_PRICE_ID=
STRIPE_PRICE_PRUVODCE_MONTHLY=
STRIPE_PRICE_PRUVODCE_YEARLY=
STRIPE_PRICE_OSVICENI_MONTHLY=
STRIPE_PRICE_OSVICENI_YEARLY=
STRIPE_PRICE_VIP_MAJESTRAT_MONTHLY=
RESEND_API_KEY=YOUR_RESEND_API_KEY
FROM_EMAIL=noreply@yourdomain.com
REPLY_TO_EMAIL=support@yourdomain.com
EMAIL_UNSUBSCRIBE_URL=
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3001
APP_URL=https://yourdomain.com
NODE_ENV=development
PORT=3001
# Local/dev safety: scheduled jobs run in production by default. Set this to true only
# when you intentionally want local cron/social jobs to run.
ENABLE_SCHEDULED_JOBS=false
DISABLE_SCHEDULED_JOBS=false
# Daily horoscope emails have their own switch so they can stay on even if general
# cron/social jobs are disabled in production. Keep disabled locally unless testing.
ENABLE_DAILY_HOROSCOPE_EMAILS=false
DISABLE_DAILY_HOROSCOPE_EMAILS=false
PERSONAL_DATA_RETENTION_DAYS=180
ANALYTICS_RETENTION_DAYS=180
ONE_TIME_ORDER_RETENTION_DAYS=90
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
# Povinné v produkci — vygeneruj: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
CSRF_SECRET=YOUR_CSRF_SECRET_MIN_32_CHARS
