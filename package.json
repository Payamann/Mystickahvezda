{
  "name": "mysticka-hvezda",
  "version": "1.0.1",
  "description": "Mystická Hvězda — astrology web application",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:sections": "node scripts/run-e2e-sections.mjs",
    "test:e2e:sections:mobile": "node scripts/run-e2e-sections.mjs --project=mobile-chrome",
    "test:e2e:api": "node scripts/run-e2e-sections.mjs --section=api",
    "test:e2e:core": "node scripts/run-e2e-sections.mjs --section=core",
    "test:e2e:content": "node scripts/run-e2e-sections.mjs --section=content",
    "test:e2e:tools": "node scripts/run-e2e-sections.mjs --section=tools",
    "test:e2e:checkout": "node scripts/run-e2e-sections.mjs --section=checkout",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "check:encoding": "python server/scripts/check-encoding.py",
    "check:hooks": "node scripts/check-hooks.mjs",
    "audit:site": "node scripts/audit-site-structure.mjs",
    "sitemap:generate": "node scripts/generate-sitemap-from-canonicals.mjs",
    "sitemap:check": "node scripts/generate-sitemap-from-canonicals.mjs --check",
    "test:verify": "npm run lint && npm run check:encoding && npm run check:hooks && npm test && npm run audit:site && npm run sitemap:check",
    "test:all": "npm run test:verify && npm run test:e2e:sections && npm run test:e2e:sections:mobile",
    "build:css": "cleancss -o css/style.v2.min.css css/style.v2.css && node scripts/update-service-worker-cache.mjs",
    "build:js": "node scripts/build-js.mjs && node scripts/update-service-worker-cache.mjs",
    "build:pwa-icons": "node server/scripts/create-pwa-icons.js && node scripts/update-service-worker-cache.mjs",
    "lint": "eslint server/ js/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-schedule": "^2.1.1",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "stripe": "^20.3.0",
    "xss": "^1.0.15",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "clean-css-cli": "^5.6.3",
    "cross-env": "^10.1.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "fontmin": "^1.1.1",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "terser": "^5.46.1"
  }
}
