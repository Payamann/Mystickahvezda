{
  "name": "mysticka-hvezda",
  "version": "1.0.1",
  "description": "Mystická Hvězda — astrology web application",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm test && npm run test:e2e",
    "build:css": "cleancss -o css/style.v2.min.css css/style.v2.css",
    "build:js": "esbuild js/*.js --minify --outdir=js/dist --bundle=false && esbuild js/main.js --bundle --minify --outfile=js/dist/main.js --platform=browser --format=esm",
    "lint": "eslint server/ js/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-schedule": "^2.1.1",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "stripe": "^20.3.0",
    "xss": "^1.0.15",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "clean-css-cli": "^5.6.3",
    "cross-env": "^10.1.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "fontmin": "^1.1.1",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "terser": "^5.46.1"
  }
}
