{
  "name": "mysticka-hvezda",
  "version": "1.0.1",
  "description": "Mystická Hvězda — astrology web application",
  "main": "server/index.js",
  "type": "module",
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "overrides": {
    "svix": "1.92.2"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:unit:server": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:unit:frontend": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --testMatch \"**/tests/frontend/**/*.test.js\"",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:smoke": "node scripts/run-e2e-sections.mjs --section=smoke",
    "test:e2e:sections": "node scripts/run-e2e-sections.mjs",
    "test:e2e:sections:mobile": "node scripts/run-e2e-sections.mjs --project=mobile-chrome",
    "test:e2e:api": "node scripts/run-e2e-sections.mjs --section=api",
    "test:e2e:core": "node scripts/run-e2e-sections.mjs --section=core",
    "test:e2e:business": "node scripts/run-e2e-sections.mjs --section=core,checkout",
    "test:e2e:content": "node scripts/run-e2e-sections.mjs --section=content",
    "test:e2e:tools": "node scripts/run-e2e-sections.mjs --section=tools",
    "test:e2e:checkout": "node scripts/run-e2e-sections.mjs --section=checkout",
    "test:e2e:activation-smoke": "playwright test tests/e2e/activation-visual-smoke.spec.js --project=chromium --workers=1",
    "test:e2e:paywall-smoke": "playwright test tests/e2e/paywall-visual-smoke.spec.js --project=chromium --workers=1",
    "test:e2e:homepage-smoke": "playwright test tests/e2e/homepage-cta-smoke.spec.js --project=chromium --workers=1",
    "test:e2e:pricing-smoke": "playwright test tests/e2e/pricing-visual-smoke.spec.js --project=chromium --workers=1",
    "test:e2e:funnel-smoke": "playwright test tests/e2e/homepage-cta-smoke.spec.js tests/e2e/pricing-visual-smoke.spec.js tests/e2e/activation-visual-smoke.spec.js tests/e2e/paywall-visual-smoke.spec.js tests/e2e/exit-intent-checkout.spec.js tests/e2e/horoscope-inline-checkout.spec.js tests/e2e/inline-paywall-checkout.spec.js --project=chromium --workers=1",
    "test:e2e:checkout-recovery": "playwright test tests/e2e/auth.spec.js tests/e2e/cenik-payment.spec.js --project=chromium --workers=1 --grep \"checkout intent prezije|post-verification checkout failure|post-verification checkout network error|post-verification telemetry outage|expired post-verification checkout|checkout start analytics outage|auth completed analytics outage|checkout auth page retry neblokuje|checkout auth form telemetry outage|checkout auth required retry|rychla navigace|login s pending checkout|mobilni login s pending checkout|pending checkout se po registraci\"",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "check:encoding": "python server/scripts/check-encoding.py",
    "check:hooks": "node scripts/check-hooks.mjs",
    "check:auth-feature-contexts": "node scripts/check-auth-feature-contexts.mjs",
    "check:ai-cost-control": "node scripts/check-ai-cost-control.mjs",
    "audit:growth-loop": "node scripts/audit-growth-loop.mjs",
    "baseline:growth-sprint": "node scripts/build-growth-sprint-baseline.mjs",
    "check:paywall-trust": "node scripts/check-paywall-trust-copy.mjs",
    "analyze:funnel": "node scripts/analyze-funnel-segments.mjs",
    "analyze:gsc": "node scripts/analyze-gsc-search-performance.mjs",
    "reconcile:stripe-subscriptions": "node scripts/reconcile-stripe-subscriptions.mjs",
    "monitor:revenue-truth": "node scripts/revenue-truth-monitor.mjs",
    "monitor:revenue-truth:production": "node scripts/revenue-truth-monitor.mjs --since-live-production",
    "monitor:revenue-truth:production:summary": "node scripts/revenue-truth-monitor.mjs --since-live-production --summary-only",
    "audit:site": "node scripts/audit-site-structure.mjs",
    "audit:tarot-assets": "node server/scripts/verify-tarot-paths.js",
    "sitemap:generate": "node scripts/generate-sitemap-from-canonicals.mjs",
    "sitemap:check": "node scripts/generate-sitemap-from-canonicals.mjs --check",
    "tarot:generate-meaning-hub": "node scripts/generate-tarot-meaning-hub.mjs",
    "verify:production": "node server/scripts/verify-production.js",
    "verify:production:commit": "node scripts/verify-production-commit.mjs",
    "smoke:production:tool-runtime": "node scripts/production-tool-runtime-smoke.mjs --production",
    "smoke:production:auth-handoff": "node scripts/production-auth-handoff-smoke.mjs --production",
    "smoke:production:pricing-handoff": "node scripts/production-pricing-handoff-smoke.mjs --production",
    "smoke:production:critical-assets": "node scripts/production-critical-assets-smoke.mjs --production",
    "deploy:guard": "node scripts/deploy-guard.mjs",
    "deploy:guard:local": "node scripts/deploy-guard.mjs --skip-remote --skip-railway --allow-dirty --base-url=http://localhost:3001",
    "test:verify": "npm run lint && npm run check:encoding && npm run check:hooks && npm run check:auth-feature-contexts && npm run check:ai-cost-control && npm run audit:growth-loop && npm run check:paywall-trust && npm run test:unit:server && npm run test:unit:frontend && npm run audit:site && npm run audit:tarot-assets && npm run sitemap:check",
    "test:all": "npm run test:verify && npm run test:e2e:sections && npm run test:e2e:sections:mobile",
    "build:css": "cleancss -o css/style.v2.min.css css/style.v2.css && cleancss -o css/home.min.css fonts/local-fonts.css css/style.v2.css css/pages/index.css && cleancss -o css/site.min.css fonts/local-fonts.css css/style.v2.css && node scripts/update-service-worker-cache.mjs",
    "build:js": "node scripts/build-js.mjs && node scripts/update-service-worker-cache.mjs",
    "build:pwa-icons": "node server/scripts/create-pwa-icons.js && node scripts/update-service-worker-cache.mjs",
    "lint": "eslint server/ js/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-schedule": "^2.1.1",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "stripe": "^20.3.0",
    "web-push": "^3.6.7",
    "xss": "^1.0.15",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "clean-css-cli": "^5.6.3",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "terser": "^5.46.1"
  }
}
